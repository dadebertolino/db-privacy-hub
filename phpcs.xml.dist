<?xml version="1.0"?>
<ruleset name="DB Privacy Hub">
	<description>Coding standard per DB Privacy Hub (WordPress Coding Standards).</description>

	<file>.</file>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/.git/*</exclude-pattern>
	<!-- File condiviso verbatim tra tutti i plugin DB (stile proprio, versionato
	     a parte): trattato come vendored. NB: non usare <rule ref="Categoria">
	     per escluderlo — importerebbe l'intera categoria di sniff. -->
	<exclude-pattern>inc/class-updater\.php</exclude-pattern>

	<!-- Modalità: mostra sniff, progress, colori; scansione parallela. -->
	<arg value="sp"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>

	<!-- Compatibilità dichiarata nel plugin header. -->
	<config name="minimum_wp_version" value="5.8"/>
	<config name="testVersion" value="7.4-"/>

	<rule ref="WordPress">
		<!-- Il progetto usa nomi file class-*.php ma senza il vincolo completo WP. -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<!-- Commenti in italiano: le regole di punteggiatura/formato docblock inglesi
		     producono solo rumore. -->
		<exclude name="Squiz.Commenting"/>
		<exclude name="Generic.Commenting"/>
		<!-- Stile consolidato del progetto: consentito allineamento libero. -->
		<exclude name="WordPress.Arrays.MultipleStatementAlignment"/>
		<exclude name="Generic.Formatting.MultipleStatementAlignment"/>
		<!-- Stile del progetto: no condizioni Yoda. -->
		<exclude name="WordPress.PHP.YodaConditions"/>
		<!-- Il plugin gestisce tabelle custom (log DSAR, archivio policy): le
		     query dirette sono l'architettura, non un incidente. dbDelta è lo
		     schema change voluto. -->
		<exclude name="WordPress.DB.DirectDatabaseQuery"/>
		<!-- I nomi tabella derivano SEMPRE da $wpdb->prefix + costante di
		     classe, mai da input; i VALORI passano tutti da prepare() (lo
		     sniff NotPrepared, più severo, resta attivo e non rileva nulla).
		     Il nuovo codice deve mantenere questo invariante. -->
		<exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
		<!-- Letture $_GET display-only (tab correnti, dbph_msg, filtri
		     elenco): nessun cambio di stato. La variante .Missing (error,
		     azioni con side effect) resta attiva. -->
		<exclude name="WordPress.Security.NonceVerification.Recommended"/>
		<!-- Scelta deliberata (v1.3.1): il modulo DSAR usa l'ora locale del
		     sito in modo coerente su salvataggio, scadenze e contatori.
		     current_time('timestamp') è parte di quell'invariante. -->
		<exclude name="WordPress.DateTime.CurrentTimeTimestamp"/>
		<!-- Export CSV in streaming su php://output: fputcsv/fclose è il
		     pattern corretto, WP_Filesystem non si applica. -->
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_fclose"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_fputs"/>
	</rule>

	<!-- Prefissi consentiti per funzioni/classi/hook globali. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="dbph"/>
				<element value="DBPH"/>
				<element value="dbwoo"/>
				<element value="dbemb"/>
				<element value="DB_GitHub_Updater"/>
				<element value="dbgu"/>
			</property>
		</properties>
	</rule>

	<!-- Text domain del plugin. -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="db-privacy-hub"/>
			</property>
		</properties>
	</rule>
</ruleset>
